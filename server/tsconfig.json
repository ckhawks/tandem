{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["./**/*.ts", "../src/lib/ws-token.ts", "../src/lib/markdown.ts"]
}
