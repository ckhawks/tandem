[Unit]
Description=Tandem — y-websocket server
After=network.target postgresql.service

[Service]
Type=simple
User=tandem
WorkingDirectory=/srv/tandem
Environment=NODE_ENV=production
EnvironmentFile=/srv/tandem/.env.local
ExecStart=/usr/bin/node server/dist/server/ws.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
