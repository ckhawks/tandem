# /root/tandem/.env — production environment for tandem.stlr.cx
# Owned by root, mode 600 (no world-read): chmod 600 .env && chown root:root .env

# Postgres — same DB you use in dev is fine.
DATABASE_URL=postgresql://tandem:CHANGE-ME@HOST:PORT/tandem

# Auth.js — generate fresh for production with:
#   openssl rand -base64 32
AUTH_SECRET=CHANGE-ME-32-BYTES-BASE64

# Public URL the app is served from.
NEXTAUTH_URL=https://tandem.stlr.cx

# WebSocket server bind — keep on loopback; nginx proxies wss://.../ws -> here.
WS_HOST=127.0.0.1
WS_PORT=1234

# Browser-side WS URL. nginx upgrades /ws/* to the loopback ws server.
NEXT_PUBLIC_WS_URL=wss://tandem.stlr.cx/ws

# Auth.js cookie name. In production over HTTPS, Auth.js uses the __Secure- prefix.
# (cookies.sessionToken in src/lib/auth.ts also sets Secure=true in NODE_ENV=production)
AUTH_COOKIE_NAME=__Secure-authjs.session-token

# Optional: Node tuning
NODE_ENV=production
