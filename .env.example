# Postgres — point at your existing DB. The `tandem` schema is created by sql/001_schema.sql
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@localhost:5432/yourdb

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-bytes-base64

# Public URL the app is served from (used for cookie domain + invite links)
NEXTAUTH_URL=http://localhost:3000

# WebSocket server config
WS_HOST=127.0.0.1
WS_PORT=1234

# Client-side URL the browser uses to connect (nginx proxies wss://yourdomain/ws -> 127.0.0.1:1234)
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# Cookie name Auth.js uses; must match the value at the WS server too
AUTH_COOKIE_NAME=authjs.session-token
